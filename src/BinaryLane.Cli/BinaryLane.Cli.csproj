<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>BinaryLane.Cli</RootNamespace>
    <AssemblyName>bl</AssemblyName>
    <Version>1.0.0</Version>

    <!-- Publishing: fully static AOT executable -->
    <PublishAot>true</PublishAot>
    <SuppressTrimAnalysisWarnings>true</SuppressTrimAnalysisWarnings>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <!-- Linux: fully static via musl + static OpenSSL -->
  <PropertyGroup Condition="'$(RuntimeIdentifier)' == 'linux-musl-x64'">
    <StaticExecutable>true</StaticExecutable>
    <StaticOpenSslLinking>true</StaticOpenSslLinking>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.0-*" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.0-*" />
    <PackageReference Include="Spectre.Console" Version="0.*" />
    <PackageReference Include="System.CommandLine" Version="2.*-*" />
  </ItemGroup>

</Project>
